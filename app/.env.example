# TMDB API Configuration
# Get your API key from https://www.themoviedb.org/settings/api
NUXT_TMDB_API_KEY=your_tmdb_api_key_here

# Gemini API Configuration
# Get your API key from https://ai.google.dev
NUXT_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
# Get these from your Supabase project settings
NUXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NUXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Server-only. Never expose this in public runtime config or client code.
NUXT_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
NUXT_PUBLIC_HCAPTCHA_SITE_KEY = your_hcaptcha_site_key_here

# Admin API Token
# Used to protect the /api/admin/tmdb-import endpoint
ADMIN_API_TOKEN=your_admin_token_here

# Upstash Redis Configuration
# Used for rate limits
UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_key_here
